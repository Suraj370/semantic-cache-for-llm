{
  "uid": "semantic-cache",
  "title": "Semantic Cache",
  "description": "Observability dashboard for github.com/suraj370/semantic-cache",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "hide": 0
      },
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "options": [
          { "text": "1m",  "value": "1m"  },
          { "text": "5m",  "value": "5m",  "selected": true },
          { "text": "15m", "value": "15m" },
          { "text": "1h",  "value": "1h"  }
        ],
        "current": { "text": "5m", "value": "5m" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Hit Rate",
      "description": "Fraction of lookups that returned a cached response (direct + semantic).",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "green",  "value": 0.8  }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(semantic_cache_lookups_total{outcome=~\"direct_hit|semantic_hit\"}[$interval])) / sum(rate(semantic_cache_lookups_total{outcome!=\"skipped\"}[$interval]))",
          "legendFormat": "Hit Rate",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Direct Hit Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(semantic_cache_lookups_total{outcome=\"direct_hit\"}[$interval])) / sum(rate(semantic_cache_lookups_total{outcome!=\"skipped\"}[$interval]))",
          "legendFormat": "Direct Hit Rate",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Semantic Hit Rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(semantic_cache_lookups_total{outcome=\"semantic_hit\"}[$interval])) / sum(rate(semantic_cache_lookups_total{outcome!=\"skipped\"}[$interval]))",
          "legendFormat": "Semantic Hit Rate",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null  },
              { "color": "red",   "value": 0.01  }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(semantic_cache_errors_total[$interval])) + sum(rate(semantic_cache_embedding_errors_total[$interval])) + sum(rate(semantic_cache_store_errors_total[$interval]))",
          "legendFormat": "Errors/s",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Lookup Outcomes",
      "description": "Rate of cache lookups per second, broken down by outcome.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (outcome) (rate(semantic_cache_lookups_total[$interval]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Lookup Latency (p50 / p95 / p99)",
      "description": "End-to-end latency of Cache.Lookup calls.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(semantic_cache_lookup_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(semantic_cache_lookup_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(semantic_cache_lookup_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Embedding Latency (p50 / p95 / p99)",
      "description": "Latency of calls to the embedding provider.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(semantic_cache_embedding_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(semantic_cache_embedding_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(semantic_cache_embedding_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Embedding Token Usage",
      "description": "Tokens consumed per second by embedding provider calls.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(semantic_cache_embedding_tokens_total[$interval])",
          "legendFormat": "Tokens/s"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Store Write Latency (p50 / p95 / p99)",
      "description": "Latency of async cache write-back operations.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(semantic_cache_store_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(semantic_cache_store_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(semantic_cache_store_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Evictions & Errors",
      "description": "Rate of TTL-expired entry evictions and internal errors by operation.",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(semantic_cache_evictions_total[$interval])",
          "legendFormat": "Evictions"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (operation) (rate(semantic_cache_errors_total[$interval]))",
          "legendFormat": "Error: {{operation}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(semantic_cache_embedding_errors_total[$interval])",
          "legendFormat": "Embedding Errors"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(semantic_cache_store_errors_total[$interval])",
          "legendFormat": "Store Errors"
        }
      ]
    }
  ]
}
