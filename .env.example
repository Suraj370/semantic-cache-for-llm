# ── Required ──────────────────────────────────────────────────────────────────
# OpenAI key used for text-embedding-3-small (embeddings) and GPT model routing.
OPENAI_API_KEY=sk-proj-


# ── Optional: provider keys ───────────────────────────────────────────────────
# Only needed when proxying claude-* models.
# ANTHROPIC_API_KEY=sk-ant-...

# Override the OpenAI-compatible base URL (Azure, local proxies, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Cache tuning ──────────────────────────────────────────────────────────────
# Maximum number of entries held in the in-memory vector store.
SEMANTIC_CACHE_MAX_SIZE=10000

# Cosine similarity cutoff for a cache hit (0–1, higher = stricter).
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.85

# Embedding model. Reduce dimensions (e.g. 512) for faster search at a small
# quality cost; leave unset to use the model default (1536 for text-embedding-3-small).
SEMANTIC_CACHE_EMBEDDING_MODEL=text-embedding-3-small
# SEMANTIC_CACHE_EMBEDDING_DIM=1536

# Default TTL for cache entries in seconds (3600 = 1 hour). Set to 0 to disable.
SEMANTIC_CACHE_TTL=3600

# Enable FAISS-backed ANN search for stores larger than FAISS_THRESHOLD entries.
SEMANTIC_CACHE_USE_FAISS=true
SEMANTIC_CACHE_FAISS_THRESHOLD=500
